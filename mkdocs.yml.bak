site_name: Lumix Documentation
site_url: https://davideferigato.github.io/Lumix/
theme:
  name: material
  features:
    - navigation.tabs
    - navigation.sections
    - toc.integrate
  palette:
    - scheme: default
      primary: indigo
      accent: indigo
nav:
  - Home: index.md
  - Architecture: architecture.md
  - Usage: usage.md
  - Modules Reference: modules.md
  - Extension Guide: extension.md
  - API Reference: api.md

plugins:
  - search
  - mkdocstrings:
      handlers:
        python:
          paths: [lumix]
          options:
            show_source: true
            show_bases: true

nav:
  - Home: index.md
  - Architecture: architecture.md
  - Usage: usage.md
  - Modules Reference: modules.md
  - Extension Guide: extension.md
  - API Reference: api.md

plugins:
  - search
  - mkdocstrings:
      handlers:
        python:
          paths: [lumix]
          options:
            show_source: true
            show_bases: true

nav:
  - Home: index.md
  - Architecture: architecture.md
  - Usage: usage.md
  - Modules Reference: modules.md
  - Extension Guide: extension.md
  - API Reference: api.md
